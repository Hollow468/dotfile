{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0"
  },
  "statusLine": {
    "type": "command",
    "command": "node ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "mcpServers": {
    "playwright-extension": {
      "command": "bunx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "javascript-typescript@claude-code-workflows": true,
    "backend-development@claude-code-workflows": true,
    "python-development@claude-code-workflows": true,
    "security-scanning@claude-code-workflows": true,
    "comprehensive-review@claude-code-workflows": true,
    "full-stack-orchestration@claude-code-workflows": true,
    "plugin-eval@claude-code-workflows": true,
    "agent-teams@claude-code-workflows": true,
    "conductor@claude-code-workflows": true,
    "code-documentation@claude-code-workflows": true,
    "ui-design@claude-code-workflows": true,
    "systems-programming@claude-code-workflows": true,
    "oh-my-claudecode@omc": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  },
  "language": "Chinese",
  "theme": "auto",
  "python": "$HOME/.claude/venv/bin/python",
  "teammateMode": "tmux",
  "hasCompletedOnboarding": true
}
